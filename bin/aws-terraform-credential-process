#!/usr/bin/env bash
set -euo pipefail

unset AWS_ENDPOINT_URL
unset AWS_PROFILE
unset AWS_SESSION_TOKEN

CACHE_DIR="${XDG_CACHE_HOME:-${HOME}/.cache}"
CACHE_FILE="${CACHE_DIR}/aws-terraform-credential-process.json"
mkdir -p "$CACHE_DIR"

# Return cached credentials if still valid (with 5-minute buffer)
if [[ -f "$CACHE_FILE" ]]; then
  age=$(( $(date +%s) - $(date -r "$CACHE_FILE" +%s) ))
  if [[ $age -lt 3300 ]]; then
    cat "$CACHE_FILE"
    exit 0
  fi
fi

export AWS_ACCESS_KEY_ID
export AWS_SECRET_ACCESS_KEY
AWS_ACCESS_KEY_ID=$(op read "op://Personal/AWS terraform/access key id")
AWS_SECRET_ACCESS_KEY=$(op read "op://Personal/AWS terraform/secret access key")
ACCOUNT_ID=$(aws sts get-caller-identity --query Account --output text)
ARN_PREFIX="arn:aws:iam::${ACCOUNT_ID}"

aws sts assume-role \
  --role-arn "${ARN_PREFIX}:role/TerraformExecutionRole" \
  --role-session-name terraform \
  --serial-number "${ARN_PREFIX}:mfa/1password" \
  --token-code "$(op item get 'AWS terraform' --otp)" \
  --region ap-northeast-1 \
  --output json | \
  jq '{Version:1,AccessKeyId:.Credentials.AccessKeyId,SecretAccessKey:.Credentials.SecretAccessKey,SessionToken:.Credentials.SessionToken,Expiration:.Credentials.Expiration}' | \
  tee >(umask 177; cat > "$CACHE_FILE")
